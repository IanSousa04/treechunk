{
  "name": "fila-impressao",
  "version": "1.0.0",
  "description": "Biblioteca para análise de código e criação de chunks estruturados.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --watch --dts",
    "prebuild": "rimraf dist",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "example": "ts-node src/example.ts"
  },
  "keywords": [
    "typescript",
    "code-analysis",
    "chunks",
    "parser"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.1.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1"
  },
  "dependencies": {
    "typescript": "^5.9.3"
  }
}
